source "https://rubygems.org"

# GitHub Pages supported Jekyll version
# Check https://pages.github.com/versions/ for latest supported version
gem "jekyll", "~> 4.3.3"

# Sass support for Jekyll
gem "jekyll-sass-converter", "~> 3.0"

# Required for Jekyll 4.x on Ruby 3.4+
# Ruby 3.4 removed these from stdlib, so they must be bundled
gem "csv"
gem "base64"

# Required for GitHub Pages - locks down the exact versions
# Run `bundle install` to generate Gemfile.lock, then commit both files
